{
  "name": "zhilv-xiaoguanjia",
  "version": "1.0.0",
  "description": "智律小管家 - 个人作息与生活管理应用",
  "main": "main.js",
  "author": "智律小管家",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win --x64",
    "build-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.zhilv.xiaoguanjia",
    "productName": "智律小管家",
    "copyright": "Copyright © 2025 智律小管家",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/**",
      "!.git/**",
      "!.github/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "智律小管家-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智律小管家"
    }
  }
}
